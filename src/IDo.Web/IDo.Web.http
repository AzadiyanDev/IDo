@IDo.Web_HostAddress = http://localhost:5115

POST {{IDo.Web_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "userName": "demo-user",
  "email": "demo@example.com",
  "password": "Password123"
}

###

POST {{IDo.Web_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "identifier": "demo-user",
  "password": "Password123"
}

###

GET {{IDo.Web_HostAddress}}/api/auth/me
Accept: application/json

